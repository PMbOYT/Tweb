<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title Budget Bliss</title> <!-- Titlul la site -->
    <link rel="stylesheet" href="@Href("~/Content/Style.css")">
    <link rel="icon" type="image/x-icon" href="~/Content/Images/bb-logo.svg"> <!-- Favicon / Site icon (logo-ul din tab sus) -->
    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")
</head>
<body>
    <header>
        <div class="navbar">
            <div class="navbar-left">
             <img src="@Url.Content("~/Content/Images/bb-logo.svg")" alt="Budget Bliss Logo" class="logo">
                <h2>Budget Bliss</h2>
            </div>
    <nav>
        <div class="navbar-buttons">
            <ul>
                <li>@Html.ActionLink("Home", "Index", "Home")</li>
                <li>@Html.ActionLink("Shop", "Shop", "Home")</li>
                <li>@Html.ActionLink("Contact", "Contact", "Home")</li>
            </ul>
        </div>
    </nav>
</div>
    </header>

    <div class="container body-content">
        @RenderBody()
        <hr />
        <footer>
            <div class="footer-container">
                <div class="footer-column">
                    <h3>Support</h3>
                    <ul>
                        <li><a href="#">Help Center</a></li>
                        <li><a href="#">Order Tracking</a></li>
                        <li><a href="#">Returns</a></li>
                    </ul>
                </div>
                <div class="footer-column">
                    <h3>About</h3>
                    <ul>
                        <li><a href="#">About Us</a></li>
                        <li><a href="#">Careers</a></li>
                        <li><a href="#">Affiliate Program</a></li>
                    </ul>
                </div>
                <div class="footer-column">
                    <h3>Follow Us</h3>
                    <div class="social-icons">
                        <ul>
                            <li><a href="#">Facebook</a></li>
                            <li><a href="#">Instagram</a></li>
                            <li><a href="#">X</a></li>
                        </ul>
                    </div>
                </div>
            </div>
            <p class="footer-bottom">&copy; 2025 Budget Bliss. All rights reserved.</p>
        </footer>
    </div>

    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    @RenderSection("scripts", required: false)
</body>
</html>
